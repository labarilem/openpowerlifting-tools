{
  "name": "openpowerlifting-tools-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "import-opl-meet": "node scripts/import-opl-meet.js",
    "import-calendar-meet": "node scripts/import-calendar-meet.js",
    "format": "node scripts/format-number-column.js",
    "compare": "node scripts/compare.js",
    "set-column": "node scripts/set-column.js",
    "compile-athletes": "node scripts/compile-athletes.js",
    "update-calendar": "node scripts/update-calendar.js",
    "generate": "node packages/opl-tools/bin/cli.js generate",
    "publish": "npm publish --workspace @labarilem/opl-tools --access public",
    "test": "node --test tests/parse/**/*.test.js",
    "test-only": "node --test --test-only tests/parse/**/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
