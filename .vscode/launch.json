{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Parse PDF",
      "program": "${workspaceFolder}/packages/opl-tools/src/federations/fipl/parse.js",
      "restart": true,
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Parse Tests (Only)",
      "runtimeExecutable": "node",
      "args": [
        "--test",
        "--test-only",
        "tests/parse/**/*.test.js"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Parse Tests",
      "runtimeExecutable": "node",
      "args": [
        "--test",
        "tests/parse/**/*.test.js"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}